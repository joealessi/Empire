<Window x:Class="EmpireGame.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        FontFamily="Segoe UI"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="320"
        MaxWidth="500">

    <Border Margin="20" CornerRadius="16" BorderThickness="1.5"
            BorderBrush="{StaticResource BorderStrongBrush}">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#202C40" Offset="0"/>
                <GradientStop Color="#0D1320" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <StackPanel Margin="28,22,28,22">

            <!-- Icon + Title (drag handle) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,0,0,12" Cursor="SizeAll"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="TitleIcon" Text="ℹ️" FontSize="22"
                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleText" Text="Message" FontSize="19"
                           FontWeight="Bold" VerticalAlignment="Center">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop x:Name="TitleGrad1" Color="#5BA0FF" Offset="0"/>
                            <GradientStop x:Name="TitleGrad2" Color="#3E8EF7" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
            </StackPanel>

            <!-- Divider -->
            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,18"/>

            <!-- Message body -->
            <TextBlock x:Name="MessageText" Text="" TextWrapping="Wrap"
                       Foreground="{StaticResource TextBrush}" FontSize="14"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       MaxWidth="440" Margin="0,0,0,22" LineHeight="22"/>

            <!-- OK button -->
            <StackPanel x:Name="OkPanel" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="OkButton" Content="OK" Width="110" Height="38"
                        FontSize="14" Background="{StaticResource AccentBrush}"
                        Foreground="White" BorderBrush="{StaticResource AccentBrush}"
                        Click="OkButton_Click"/>
            </StackPanel>

            <!-- Yes / No buttons -->
            <StackPanel x:Name="YesNoPanel" Orientation="Horizontal"
                        HorizontalAlignment="Center" Visibility="Collapsed">
                <Button Content="YES" Width="110" Height="38" FontSize="14"
                        Background="{StaticResource SuccessBrush}" Foreground="White"
                        BorderBrush="{StaticResource SuccessBrush}"
                        Click="YesButton_Click" Margin="0,0,14,0"/>
                <Button Content="NO" Width="110" Height="38" FontSize="14"
                        Background="{StaticResource DangerBrush}" Foreground="White"
                        BorderBrush="{StaticResource DangerBrush}"
                        Click="NoButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
