                                                    <DropShadowEffect Color="Black" Direction="320" ShadowDepth="2" Opacity="0.4"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                            <Image Source="Resources/Empire_Icons/BuildBase.png" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                                <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                                <Setter TargetName="Highlight" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- 4:30 position - Build Bridge (Sapper) -->
                            <Button x:Name="CircularBuildBridgeButton" Width="44" Height="44" Click="BuildBridgeButton_Click" 
                                    Canvas.Left="130" Canvas.Top="136" ToolTip="Build Bridge" Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="ButtonBg" Fill="#4a4a5a" Stroke="#6b6b7b" StrokeThickness="2">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="Black" Direction="320" ShadowDepth="2" Opacity="0.4"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                            <Image Source="Resources/Empire_Icons/BuildBridge.png" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                                <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                                <Setter TargetName="Highlight" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- 10:30 position - Cancel Build (Sapper) -->
                            <Button x:Name="CircularCancelBuildButton" Width="44" Height="44" Click="CancelBuildButton_Click" 
                                    Canvas.Left="26" Canvas.Top="20" ToolTip="Cancel Build" Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="ButtonBg" Fill="#5a2a2a" Stroke="#7b3d3d" StrokeThickness="2">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="Black" Direction="320" ShadowDepth="2" Opacity="0.4"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                            <Image Source="Resources/Empire_Icons/CancelBuild.png" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                                <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                                <Setter TargetName="Highlight" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- 1:30 - Build Mine (Miner) [generic glyph icon] -->
                            <Button x:Name="CircularBuildMineButton" Width="44" Height="44" Click="BuildMineButton_Click"
                                    Canvas.Left="130" Canvas.Top="20" ToolTip="Build Mine" Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="ButtonBg" Fill="#5a4a2a" Stroke="#7b6b3d" StrokeThickness="2"/>
                                            <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                            <TextBlock Text="⛏️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                                <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- 7:30 - Disrupt Supply Line (Sapper) [generic glyph icon] -->
                            <Button x:Name="CircularDisruptButton" Width="44" Height="44" Click="DisruptButton_Click"
                                    Canvas.Left="26" Canvas.Top="136" ToolTip="Disrupt Supply Line" Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="ButtonBg" Fill="#5a2a2a" Stroke="#7b3d3d" StrokeThickness="2"/>
                                            <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                            <TextBlock Text="🚫" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                                <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- 7:30 - Stop Disrupting (Sapper, toggled) [generic glyph icon] -->
                            <Button x:Name="CircularStopDisruptButton" Width="44" Height="44" Click="StopDisruptButton_Click"
                                    Canvas.Left="26" Canvas.Top="136" ToolTip="Stop Disrupting" Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="ButtonBg" Fill="#2a4a2a" Stroke="#3d6b3d" StrokeThickness="2"/>
                                            <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                            <TextBlock Text="✋" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                                <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Canvas>

                        <!-- Life Bar -->
                        <TextBlock Text="Life:" Foreground="White" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,10">
                            <ProgressBar x:Name="LifeProgressBar" Height="20" Minimum="0" Maximum="100"/>
                            <TextBlock x:Name="LifeProgressText" Text="0/0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                        </Grid>

                        <!-- Movement Bar -->
                        <TextBlock Text="Movement:" Foreground="White" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,10">
                            <ProgressBar x:Name="MovementProgressBar" Height="20" Minimum="0" Maximum="100"/>
                            <TextBlock x:Name="MovementProgressText" Text="0/0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                        </Grid>

                        <!-- Fuel Gauge (Air Units) -->
                        <StackPanel x:Name="FuelGaugePanel" Visibility="Collapsed" Margin="0,0,0,10">
                            <TextBlock Text="Fuel:" Foreground="White" Margin="0,0,0,2"/>
                            <Grid Margin="0,0,0,5">
                                <ProgressBar x:Name="FuelProgressBar" Height="20" Minimum="0" Maximum="100"/>
                                <TextBlock x:Name="FuelProgressText" Text="0/0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Grid>
                            <TextBlock x:Name="FuelDistanceText" Text="Distance to base: --" Foreground="Cyan" FontSize="11"/>
                            <TextBlock x:Name="FuelWarningText" Text="" Foreground="Red" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="MissionEscortText" Text="" Foreground="LightSkyBlue" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0" Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- Submarine Panel -->
                        <StackPanel x:Name="SubmarinePanel" Visibility="Collapsed" Margin="0,0,0,10">
                            <TextBlock x:Name="SubmarineStatusText" Text="Status" Foreground="Cyan" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Carrier/Transport Capacity -->
                        <StackPanel x:Name="CarrierCapacityPanel" Visibility="Collapsed" Margin="0,0,0,10">
                            <TextBlock x:Name="CarrierCapacityLabel" Text="Capacity:" Foreground="White" Margin="0,0,0,2"/>
                            <Grid Margin="0,0,0,5">
                                <ProgressBar x:Name="CarrierCapacityBar" Height="20" Minimum="0" Maximum="100"/>
                                <TextBlock x:Name="CarrierCapacityText" Text="0/0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Grid>
                            <ListBox x:Name="CarrierContentsList" Height="80"/>
                        </StackPanel>

                        <!-- Special Unit Warnings/Info -->
                        <TextBlock x:Name="PatrolBoatWarningText" Visibility="Collapsed" Foreground="Orange" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock x:Name="ArtilleryRangeText" Visibility="Collapsed" Foreground="Yellow" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock x:Name="AntiAircraftProximityText" Visibility="Collapsed" Foreground="LightBlue" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock x:Name="SpyStatusText" Visibility="Collapsed" Foreground="Magenta" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock x:Name="SapperBuildText" Visibility="Collapsed" Foreground="Cyan" TextWrapping="Wrap" Margin="0,0,0,5" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Structure Info Panel -->
                <Border x:Name="StructureInfoPanel" Visibility="Collapsed" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="StructureNameText" Text="Structure" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBlock x:Name="StructureLifeText" Text="Life" Foreground="LightGray" Margin="0,0,0,5"/>
                        <TextBlock x:Name="DefenseBonusText" Text="Defense" Foreground="LightBlue" Margin="0,0,0,10"/>

                        <!-- Base/City facilities (hidden for mines) -->
                        <StackPanel x:Name="StructureFacilitiesPanel">
                        <!-- Airport -->
                        <TextBlock Text="🛫 Airport" FontSize="14" FontWeight="Bold" Foreground="Cyan" Margin="0,0,0,5"/>
                        <TextBlock x:Name="AirportCapacityText" Text="Capacity: 0/6" Foreground="White" Margin="0,0,0,5"/>
                        <ListBox x:Name="AirportList" Height="100" Margin="0,0,0,5" SelectionChanged="AirportList_SelectionChanged"/>
                        <WrapPanel Margin="0,0,0,10">
                            <Button x:Name="TakeOffButton" Content="Take Off" Width="80" Margin="2" Click="TakeOffButton_Click"/>
                            <Button x:Name="RepairAircraftButton" Content="Repair" Width="80" Margin="2" Click="RepairAircraftButton_Click"/>
                        </WrapPanel>

                        <!-- Shipyard -->
                        <StackPanel x:Name="ShipyardLabel">
                            <TextBlock Text="⚓ Shipyard" FontSize="14" FontWeight="Bold" Foreground="DodgerBlue" Margin="0,0,0,5"/>
                            <TextBlock x:Name="ShipyardCapacityText" Text="Capacity: 0/3" Foreground="White" Margin="0,0,0,5"/>
                            <ListBox x:Name="ShipyardList" Height="80" Margin="0,0,0,5" SelectionChanged="ShipyardList_SelectionChanged"/>
                            <WrapPanel Margin="0,0,0,10">
                                <Button x:Name="LaunchShipButton" Content="Launch" Width="80" Margin="2" Click="LaunchShipButton_Click"/>
                                <Button x:Name="RepairShipButton" Content="Repair" Width="80" Margin="2" Click="RepairShipButton_Click"/>
                            </WrapPanel>
                        </StackPanel>

                        <!-- Motor Pool -->
                        <TextBlock Text="🚗 Motor Pool" FontSize="14" FontWeight="Bold" Foreground="Orange" Margin="0,0,0,5"/>
                        <ListBox x:Name="MotorPoolList" Height="80" Margin="0,0,0,5" SelectionChanged="MotorPoolList_SelectionChanged"/>
                        <Button x:Name="DeployMotorButton" Content="Deploy Unit" Margin="0,0,0,10" Click="DeployMotorButton_Click"/>

                        <!-- Barracks -->
                        <TextBlock Text="🪖 Barracks" FontSize="14" FontWeight="Bold" Foreground="LimeGreen" Margin="0,0,0,5"/>
                        <TextBlock x:Name="BarracksCapacityText" Text="Capacity: 0/10" Foreground="White" Margin="0,0,0,5"/>
                        <ListBox x:Name="BarracksList" Height="80" Margin="0,0,0,5" SelectionChanged="BarracksList_SelectionChanged"/>
                        <Button x:Name="DeployArmyButton" Content="Deploy Army" Margin="0,0,0,10" Click="DeployArmyButton_Click"/>

                        <!-- Production Queue -->
                        <TextBlock Text="⚙️ Production Queue" FontSize="14" FontWeight="Bold" Foreground="Yellow" Margin="0,10,0,5"/>
                        <ListBox x:Name="ProductionQueueList" Height="100" Margin="0,0,0,10"/>

                        <!-- Build Unit -->
                        <TextBlock Text="Build Unit:" Foreground="White" Margin="0,0,0,5"/>
                        <ComboBox x:Name="UnitTypesCombo" Margin="0,0,0,5"/>
                        <Button x:Name="BuildUnitButton" Content="Add to Queue" Click="BuildUnitButton_Click"/>

                        <!-- Civic Upgrades tile -->
                        <Border Margin="0,14,0,4" CornerRadius="8" BorderThickness="1"
                                BorderBrush="#4a3800" Padding="10,8,10,6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#1a1400" Offset="0"/>
                                    <GradientStop Color="#0e0c00" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel>
                                <!-- Toggle header -->
                                <Grid Cursor="Hand" MouseLeftButtonDown="CivicUpgradesToggle_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🏛️ Civic Upgrades"
                                               FontSize="14" FontWeight="Bold" Foreground="#FFD43B"/>
                                    <Border Grid.Column="1" Width="20" Height="20" CornerRadius="4"
                                            Background="#2a1e00" BorderBrush="#6a5000" BorderThickness="1"
                                            VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock x:Name="CivicUpgradesToggleIcon" Text="+"
                                                   FontSize="13" FontWeight="Bold" Foreground="#FFD43B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <!-- Slide-out content -->
                                <Border x:Name="CivicUpgradesContainer" ClipToBounds="True" MaxHeight="0">
                                    <WrapPanel Margin="0,8,0,2">
                                        <Button x:Name="UpgIndustryButton" Margin="2" Click="UpgIndustry_Click"/>
                                        <Button x:Name="UpgFortifyButton" Margin="2" Click="UpgFortify_Click"/>
                                        <Button x:Name="UpgWatchtowerButton" Margin="2" Click="UpgWatchtower_Click"/>
                                        <Button x:Name="UpgHousingButton" Margin="2" Click="UpgHousing_Click"/>
                                        <Button x:Name="UpgTreasuryButton" Margin="2" Click="UpgTreasury_Click"/>
                                        <Button x:Name="UpgMilitary1Button" Margin="2" Click="UpgMilitary1_Click"/>
                                        <Button x:Name="UpgMilitary2Button" Margin="2" Click="UpgMilitary2_Click"/>
                                        <Button x:Name="UpgHighTechButton" Margin="2" Click="UpgHighTech_Click"/>
                                        <Button x:Name="UpgConscriptButton" Margin="2" Click="UpgConscript_Click"/>
                                        <Button x:Name="UpgRepairButton" Margin="2" Click="UpgRepair_Click"/>
                                    </WrapPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        </StackPanel>

                        <!-- Mine actions (mines can only produce Miners) -->
                        <StackPanel x:Name="MineActionsPanel" Visibility="Collapsed">
                            <TextBlock Text="⛏️ Mine" FontSize="14" FontWeight="Bold" Foreground="Gold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="MineInfoText" Text="" Foreground="LightGray" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Button x:Name="BuildMinerFromMineButton" Content="Build Miner (👥2)" Click="BuildMinerFromMineButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Game Control Buttons -->
                <StackPanel Orientation="Vertical" Margin="0,20,0,0">
                    <!-- Next Unit Button -->
                    <Button x:Name="NextUnitButton" Content="Next Unit (Space)" Height="40" Margin="0,0,0,10"
                            Click="NextUnitButton_Click" Style="{StaticResource AccentButton}"/>

                    <!-- Circular Game Controls Cluster -->
                    <Canvas Width="200" Height="200" HorizontalAlignment="Center" Margin="0,6,0,0">

                        <!-- 12 o'clock: New Game (hidden until game over) -->
                        <Button x:Name="NewGameButton" Width="44" Height="44"
                                Canvas.Left="78" Canvas.Top="5"
                                Click="NewGameButton_Click" ToolTip="New Game"
                                Visibility="Collapsed" Background="Transparent" BorderBrush="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                <Ellipse x:Name="Bg" Fill="#1a4a1a" Stroke="#2fb85b" StrokeThickness="2">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="2" Opacity="0.4"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                <TextBlock Text="▶" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#2fb85b"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                    <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                    <Setter TargetName="Highlight" Property="Opacity" Value="0.4"/>
                                </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 3 o'clock: Toggle Supply Lines -->
                        <Button x:Name="ToggleSupplyLinesButton" Width="44" Height="44"
                                Canvas.Left="151" Canvas.Top="78"
                                Click="ToggleSupplyLinesButton_Click" ToolTip="Show/Hide Supply Lines"
                                Background="Transparent" BorderBrush="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                <Ellipse x:Name="Bg" Fill="#2a3a5a" Stroke="#3d5b7b" StrokeThickness="2">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="2" Opacity="0.4"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                <TextBlock Text="🔗" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                    <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                    <Setter TargetName="Highlight" Property="Opacity" Value="0.4"/>
                                </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 6 o'clock: Surrender -->
                        <Button x:Name="SurrenderButton" Width="44" Height="44"
                                Canvas.Left="78" Canvas.Top="151"
                                Click="SurrenderButton_Click" ToolTip="Surrender"
                                Background="Transparent" BorderBrush="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                <Ellipse x:Name="Bg" Fill="#4a1a1a" Stroke="#6b2a2a" StrokeThickness="2">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="2" Opacity="0.4"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                <Image Source="/Resources/white-flag.png" Width="26" Height="26"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                    <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                    <Setter TargetName="Highlight" Property="Opacity" Value="0.4"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 9 o'clock: Exit Game -->
                        <Button x:Name="ExitGameButton" Width="44" Height="44"
                                Canvas.Left="5" Canvas.Top="78"
                                Click="ExitGameButton_Click" ToolTip="Exit Game"
                                Background="Transparent" BorderBrush="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                <Ellipse x:Name="Bg" Fill="#2a2a2a" Stroke="#4a4a4a" StrokeThickness="2">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="2" Opacity="0.4"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                <TextBlock Text="✖" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#93A1B5"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                    <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                    <Setter TargetName="Highlight" Property="Opacity" Value="0.4"/>
                                </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 1:30: Info / Codex -->
                        <Button x:Name="GameInfoButton" Width="44" Height="44"
                                Canvas.Left="130" Canvas.Top="20"
                                Click="GameInfoButton_Click" ToolTip="Codex — terrain &amp; unit reference"
                                Background="Transparent" BorderBrush="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse x:Name="Bg" Fill="#1a2a4a" Stroke="#3d5b7b" StrokeThickness="2">
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="2" Opacity="0.4"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                        <TextBlock Text="📖" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                            <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                            <Setter TargetName="Highlight" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Center: End Turn -->
                        <Button x:Name="EndTurnButton" Width="80" Height="80"
                                Canvas.Left="60" Canvas.Top="60"
                                Click="EndTurnButton_Click"
                                Background="Transparent" BorderBrush="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                <Ellipse x:Name="Bg" Fill="#2a4a2a" Stroke="#3d6b3d" StrokeThickness="3">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" Opacity="0.5"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Ellipse x:Name="Highlight" Fill="Transparent" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                    <Setter TargetName="Highlight" Property="Opacity" Value="0.2"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Highlight" Property="Fill" Value="White"/>
                                    <Setter TargetName="Highlight" Property="Opacity" Value="0.4"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Image x:Name="endTurnImage" Width="40" Height="40"
                                   Source="/Resources/fast-forward.png"/>
                        </Button>

                    </Canvas>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        <!-- DEBUG CONSOLE OVERLAY (Esc Esc C after clicking message log) -->
        <Border x:Name="DebugConsolePanel" Grid.ColumnSpan="4"
                VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                Background="#DD111111" BorderBrush="#8800FF80" BorderThickness="0,1,0,0"
                Padding="10,8" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🐛 DEBUG ›" Foreground="#00FF80" FontFamily="Consolas" FontSize="14"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="DebugCommandInput" Width="500" Background="#1A1A1A" Foreground="#00FF80"
                         CaretBrush="#00FF80" BorderBrush="#00FF80" BorderThickness="1"
                         FontFamily="Consolas" FontSize="14" Padding="4,2"
                         KeyDown="DebugCommandInput_KeyDown"/>
                <TextBlock x:Name="DebugResultText" Foreground="#FFD700" FontFamily="Consolas" FontSize="13"
                           Margin="14,0,0,0" VerticalAlignment="Center" TextWrapping="NoWrap"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>